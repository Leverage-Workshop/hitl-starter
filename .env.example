# Copy to .env and fill in values. Never commit .env.

# Neon Postgres connection string (from Neon dashboard → Connection Details)
DATABASE_URL=

# Better Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL for Better Auth callbacks
# Dev:  http://localhost:3000
# Prod: https://your-production-domain.com
BETTER_AUTH_URL=

# Password for the caleb@hitl.local admin seed user
# Used once by: npx tsx scripts/seed.ts
SEED_ADMIN_PASSWORD=

# --- trigger.dev (quote-desk engine; feat-014) -------------------------------
# Project ref from the trigger.dev dashboard (proj_…). Used by trigger.config.ts.
TRIGGER_PROJECT_REF=
# Environment secret key for `npx trigger.dev@latest deploy`.
TRIGGER_SECRET_KEY=
# Personal access token for the CLI / MCP (`npx trigger.dev@latest dev`).
TRIGGER_ACCESS_TOKEN=

# --- LLM via OpenRouter (AI SDK; feat-014/015/017) ---------------------------
# OpenRouter API key for the AI SDK model factory (trigger/lib/ai.ts).
OPENROUTER_API_KEY=

# --- FastAPI data API (workflow_items writer; feat-014/016/017) --------------
# Base URL of the FastAPI service tasks call to enqueue/settle workflow_items.
DATA_API_BASE_URL=
# Optional bearer token if the data API requires auth (trigger/lib/data-api.ts).
DATA_API_TOKEN=

# --- Gmail RFQ intake (quote-desk; feat-015) ---------------------------------
# Delegated OAuth access token (gmail.readonly) for quotes@halberd-co.com.
# The scaffold reads it directly; production should mint/refresh it per call.
GMAIL_ACCESS_TOKEN=
# Shared token verifying the Pub/Sub push subscription hitting /api/gmail/push
# (set the subscription's push URL to .../api/gmail/push?token=THIS).
PUBSUB_VERIFICATION_TOKEN=
# Watched mailbox for the scheduled poll fallback (default quotes@halberd-co.com).
GMAIL_WATCH_ADDRESS=
# Gmail history cursor for the quote-desk-poll fallback (from users.watch).
GMAIL_START_HISTORY_ID=

# --- Quote send-on-approval (quote-desk; feat-017) ---------------------------
# Delegated OAuth token with gmail.send scope for the approved-quote reply.
# Falls back to GMAIL_ACCESS_TOKEN when unset (trigger/quote-desk-send.ts).
GMAIL_SEND_TOKEN=
# Sender address on the outbound quote reply (default quotes@halberd-co.com).
QUOTE_FROM_ADDRESS=
# HMAC secret the /api/quote-desk/send route verifies on the feat-006 dispatch
# (must equal the quote-desk workflow's webhookSecret used to sign decisions).
QUOTE_SEND_WEBHOOK_SECRET=
