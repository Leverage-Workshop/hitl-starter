# Copy to .env and fill in values. Never commit .env.

# Neon Postgres connection string (from Neon dashboard → Connection Details)
DATABASE_URL=

# Better Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL for Better Auth callbacks
# Dev:  http://localhost:3000
# Prod: https://your-production-domain.com
BETTER_AUTH_URL=

# Password for the caleb@hitl.local admin seed user
# Used once by: npx tsx scripts/seed.ts
SEED_ADMIN_PASSWORD=

# --- trigger.dev (quote-desk engine; feat-014) -------------------------------
# Project ref from the trigger.dev dashboard (proj_…). Used by trigger.config.ts.
TRIGGER_PROJECT_REF=
# Environment secret key for `npx trigger.dev@latest deploy`.
TRIGGER_SECRET_KEY=
# Personal access token for the CLI / MCP (`npx trigger.dev@latest dev`).
TRIGGER_ACCESS_TOKEN=

# --- LLM via OpenRouter (AI SDK; feat-014/015/017) ---------------------------
# OpenRouter API key for the AI SDK model factory (trigger/lib/ai.ts).
OPENROUTER_API_KEY=

# --- FastAPI data API (workflow_items writer; feat-014/016/017) --------------
# Base URL of the FastAPI service tasks call to enqueue/settle workflow_items.
DATA_API_BASE_URL=
# Optional bearer token if the data API requires auth (trigger/lib/data-api.ts).
DATA_API_TOKEN=
