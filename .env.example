# Copy to .env and fill in values. Never commit .env.

# Neon Postgres connection string (from Neon dashboard → Connection Details)
DATABASE_URL=

# Better Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL for Better Auth callbacks
# Dev:  http://localhost:3000
# Prod: https://your-production-domain.com
BETTER_AUTH_URL=

# Password for the caleb@hitl.local admin seed user
# Used once by: npx tsx scripts/seed.ts
SEED_ADMIN_PASSWORD=
