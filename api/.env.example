# Halberd & Co — FastAPI workflow service environment
# Copy to api/.env and fill in. Never commit api/.env.
# This file is SEPARATE from the Next.js .env at the repo root.

# Neon connection string — MUST use the asyncpg scheme for SQLAlchemy async.
# Note the +asyncpg, not the plain postgresql:// scheme Next.js/Drizzle uses.
#   postgresql+asyncpg://USER:PASSWORD@HOST/DB?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech/halberd?ssl=require

# Anthropic key for LangGraph / Claude workflow calls
ANTHROPIC_API_KEY=

# Better Auth secret — used to validate session tokens passed from Next.js.
# Must match the value the Next.js app signs sessions with. Rotate regularly.
BETTER_AUTH_SECRET=

# Optional: secret used to verify inbound trigger.dev job requests
TRIGGER_DOT_DEV_SECRET=
